# Backend API URL Configuration
# ================================
# Choose ONE option based on your setup:

# Option 1: Local Backend (when running backend on same PC)
VITE_API_URL=http://localhost:5001/api

# Option 2: Remote Backend (when backend runs on different PC via ngrok)
#VITE_API_URL=https://your-ngrok-url.ngrok-free.dev/api

# The app will automatically:
# - Use the configured URL
# - Fall back to localhost if remote fails
# - Switch between them dynamically

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017

# JWT Secret Key
JWT_SECRET_KEY=your-secret-key-here

# File Upload Limits
MAX_CONTENT_LENGTH=524288000

# OAuth Configuration (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
